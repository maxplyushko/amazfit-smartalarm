{
  "configVersion": "v3",
  "app": {
    "appId": 1000099,
    "appName": "Smart Alarm",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "2.1.0"
    },
    "icon": "icon.png",
    "vender": "Max Restinov",
    "description": "Wake up during light sleep for a fresher morning"
  },
  "permissions": [
    "device:os.alarm",
    "device:os.notification",
    "data:user.hd.sleep"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "2.0.0",
      "target": "3.0.0",
      "minVersion": "2.0.0"
    },
    "type": 0
  },
  "targets": {
    "gtr-4": {
      "module": {
        "page": {
          "pages": [
            "page/config/index",
            "page/wake/index",
            "page/time-picker/index",
            "page/window-picker/index"
          ]
        },
        "app-service": {
          "services": [
            "app-service/wake_service",
            "app-service/dismiss_service"
          ]
        }
      },
      "platforms": [
        { "name": "gtr4", "deviceSource": 7930112 },
        { "name": "gtr4", "deviceSource": 7930113 }
      ],
      "designWidth": 466
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Smart Alarm"
    },
    "zh-CN": {
      "appName": "智能闹钟"
    }
  },
  "defaultLanguage": "en-US"
}
